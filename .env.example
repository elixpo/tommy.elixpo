# ─────────────────────────────────────────────────────────────────
# Tommy Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file — it contains secrets.
# ─────────────────────────────────────────────────────────────────


# ── Discord ─────────────────────────────────────────────────────
# 1. Go to https://discord.com/developers/applications
# 2. Create an application → go to "Bot" tab → click "Reset Token"
# 3. Copy the token here
# 4. Under "Privileged Gateway Intents", enable:
#      - MESSAGE CONTENT INTENT
#      - SERVER MEMBERS INTENT (optional, for role checks)
DISCORD_TOKEN=


# ── GitHub App ──────────────────────────────────────────────────
# Tommy uses a GitHub App for authentication (more secure than PATs).
#
# To create one:
#   1. Go to https://github.com/settings/apps → "New GitHub App"
#   2. Set a name (e.g. "tommy-bot")
#   3. Homepage URL: any URL (e.g. your repo URL)
#   4. Uncheck "Webhook → Active" (Tommy handles its own webhooks)
#   5. Permissions needed:
#        - Repository: Contents (Read & Write), Issues (Read & Write),
#          Pull Requests (Read & Write), Metadata (Read)
#   6. Click "Create GitHub App"
#   7. Copy the App ID below
#   8. Scroll down → "Generate a private key" → save the .pem file
#   9. Install the app on your repo:
#        App settings → "Install App" → select your repo
#  10. Copy the Installation ID from the URL:
#        https://github.com/settings/installations/XXXXX ← this number
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=./tommy.pem
GITHUB_INSTALLATION_ID=

# Optional: GitHub PAT with "project" scope — only needed if you use
# the Project Manager workflow with GitHub Projects V2 boards.
# Create at: https://github.com/settings/tokens → "Fine-grained tokens"
GITHUB_PROJECT_PAT=


# ── AI Provider ─────────────────────────────────────────────────
# Token for the AI text/image API configured in .github/tommy.yml.
# Default config uses Pollinations (free, no signup):
#   https://enter.pollinations.ai
# If you switch to OpenAI or another provider, put that key here. It has to be 
# /v1/chat/completions compatible if you want to use the PR review workflow.
POLLINATIONS_TOKEN=


# ── Embeddings ──────────────────────────────────────────────────
# Only needed when config.json → embeddings.provider is "api".
# Leave blank if using provider "local" (runs model on your machine).
#
# For OpenAI embeddings: use your OpenAI API key from
#   https://platform.openai.com/api-keys
# For other providers: use whatever API key they require.
EMBEDDINGS_API_KEY=


# ── Optional Features ───────────────────────────────────────────
# Override config.json feature flags via env vars (optional).
# DOC_EMBEDDINGS_ENABLED=true
