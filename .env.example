# Discord Bot Token
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# GitHub Personal Access Token
# Needs 'repo' scope for triggering workflows via repository_dispatch
# The actual issue creation uses the workflow's GITHUB_TOKEN (github-actions[bot])
POLLI_PAT=your_github_pat_here

# GitHub Repository for creating issues (format: owner/repo)
# Default: pollinations/pollinations
GITHUB_REPO=pollinations/pollinations

# GitHub Project PAT (for ProjectV2 access)
# GitHub Apps CANNOT access ProjectV2 - you need a PAT with 'project' scope
# Create a classic PAT with 'project' scope, or fine-grained with 'project:read' + 'project:write'
# Optional - only needed if you want to interact with GitHub Projects
GITHUB_PROJECT_PAT=

# Pollinations API Token
# Get from https://enter.pollinations.ai
# Optional but recommended to avoid rate limits
POLLINATIONS_TOKEN=your_pollinations_token_here

# Pollinations AI Model
# Options: gemini-large, openai, claude, etc.
# Default: gemini-large
POLLINATIONS_MODEL=gemini-large

# Admin Role ID (Discord role ID for admin privileges)
# Users with this role can close/edit/assign issues
# Optional - leave empty to disable admin features
ADMIN_ROLE_ID=

# =============================================================================
# GITHUB APP AUTHENTICATION (preferred over PAT)
# =============================================================================

# GitHub App ID
GITHUB_APP_ID=

# Path to private key file
GITHUB_PRIVATE_KEY_PATH=./polly.pem

# Installation ID
GITHUB_INSTALLATION_ID=

# =============================================================================
# GITHUB WEBHOOK SERVER (for bidirectional GitHub <-> Discord)
# =============================================================================

# Port for webhook server (default: 8002)
WEBHOOK_PORT=8002

# Webhook secret for signature verification (optional but recommended)
GITHUB_WEBHOOK_SECRET=

# GitHub bot username (to detect @mentions)
GITHUB_BOT_USERNAME=pollinations-ci

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Sandbox Mode for Code Agent (default: false)
# When enabled, code agent runs in isolated Docker containers
SANDBOX_ENABLED=false

# Local Embeddings for Code Search (default: false)
# When enabled, clones repo and creates embeddings for semantic code search
# Requires: sentence-transformers, chromadb
LOCAL_EMBEDDINGS_ENABLED=false

# Repository to embed (only used if LOCAL_EMBEDDINGS_ENABLED=true)
EMBEDDINGS_REPO=pollinations/pollinations

# Path to local repo clone (for sandbox file copying)
REPO_PATH=
